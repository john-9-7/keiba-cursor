ENABLE_AUTH=false
AUTH_USER=your_id
AUTH_PASS=your_strong_password

# 競馬クラスター Cookie（laravel_session=...; XSRF-TOKEN=...）
# 設定すると「保存済みを使う」で iPhone からも貼り付け不要（Render では再デプロイ後も残る）
# KEIBA_COOKIE=
# KEIBA_COOKIE_ARCHIVE=

# スモークテスト（任意）
# SMOKE_BASE_URL=https://keiba-cursor.onrender.com
# SMOKE_AUTH_USER=your_id
# SMOKE_AUTH_PASS=your_strong_password
# SMOKE_COOKIE_PURPOSE=live
